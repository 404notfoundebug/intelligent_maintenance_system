# TiDB Cloud Serverless example.
# Copy the values from TiDB Cloud "Connect" panel and replace placeholders.

APP_ENV=production
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# TiDB Cloud uses the MySQL protocol. Keep mysql+pymysql for this project.
# Typical TiDB Cloud Serverless port: 4000
# Add the SSL parameters shown by the TiDB Cloud console if they differ.
DATABASE_URL=mysql+pymysql://<tidb_user>:<tidb_password>@<tidb_host>:4000/<database_name>?charset=utf8mb4&ssl_verify_cert=true&ssl_verify_identity=true

UPLOAD_DIR=./uploads

# Optional OpenAI-compatible LLM settings.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=
