# Copy this file to .env and fill in real credentials.
# Do not commit .env.

APP_NAME=智能电梯扶梯维保系统
APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local MySQL example:
# DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/intelligent_maintenance?charset=utf8mb4

# TiDB Cloud example:
# DATABASE_URL=mysql+pymysql://<tidb_user>:<tidb_password>@<tidb_host>:4000/intelligent_maintenance?charset=utf8mb4&ssl_verify_cert=true&ssl_verify_identity=true
DATABASE_URL=

UPLOAD_DIR=./uploads

# Optional OpenAI-compatible LLM settings.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=
