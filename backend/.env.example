# Copy this file to .env and fill in real credentials.
# Do not commit .env.

APP_NAME=智能电梯扶梯维保系统
APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local MySQL 8.0. Replace the user and password with your local credentials.
# URL-encode special characters in the password, for example @ as %40.
DATABASE_URL=mysql+pymysql://maintenance_app:your_mysql_password@127.0.0.1:3306/intelligent_maintenance?charset=utf8mb4

UPLOAD_DIR=./uploads

# Optional OpenAI-compatible LLM settings.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=
