# =========================
# Python虚拟环境
# =========================
.venv/
venv/
env/
ENV/

# =========================
# Python缓存文件
# =========================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# =========================
# 环境变量配置
# 注意：.env里可能有数据库密码、API Key，不能上传GitHub
# =========================
.env
.env.*

# 保留模板文件
!.env.example
!.env.*.example

# =========================
# 上传文件和运行时文件
# =========================
uploads/
logs/
*.log

# =========================
# 数据库临时文件
# =========================
*.sqlite3
*.db

# =========================
# VSCode配置
# =========================
.vscode/
.workbuddy

# =========================
# Windows和macOS系统文件
# =========================
Thumbs.db
Desktop.ini
.DS_Store

# =========================
# 前端依赖和构建产物
# 后面做Vue前端时会用到
# =========================
node_modules/
dist/
build/

# =========================
# 测试和覆盖率文件
# =========================
.pytest_cache/
.coverage
htmlcov/

# =========================
# 临时文件
# =========================
*.tmp
*.bak
*.swp
